# Configuration frontend (renommez en .env)
VITE_API_URL=http://localhost:3000

# En production, remplacez par votre vrai domaine :
# VITE_API_URL=https://api.votre-domaine.com

# ── Sécurité JWT ─────────────────────────────────────────────
# Doit être IDENTIQUE à la valeur dans backend/.env
JWT_SECRET=your_generated_jwt_secret_here_replace_me