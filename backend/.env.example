# Configuration backend
# ⚠️  COPIER CE FICHIER EN .env ET REMPLIR TOUTES LES VALEURS AVANT DÉMARRAGE ⚠️

# ── Environnement ────────────────────────────────────────────
NODE_ENV=development
# En production : NODE_ENV=production
PORT=3000

# ── Sécurité JWT ─────────────────────────────────────────────
# Générer avec : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_generated_jwt_secret_here_replace_me

# ── CORS (origines autorisées en production) ─────────────────
# Séparer plusieurs domaines par une virgule, sans espaces entre guillemets
# Exemple : https://sarmates-music.com,https://www.sarmates-music.com
ALLOWED_ORIGINS=https://votre-domaine.com

# ── Email SMTP ───────────────────────────────────────────────
# Hostinger :
#   SMTP_HOST=smtp.hostinger.com  SMTP_PORT=587  SMTP_SECURE=false
# OVH :
#   SMTP_HOST=ssl0.ovh.net        SMTP_PORT=587  SMTP_SECURE=false
# Gmail (app password) :
#   SMTP_HOST=smtp.gmail.com      SMTP_PORT=465  SMTP_SECURE=true
# Autre serveur :
#   SMTP_HOST=mail.votre-domaine.com  SMTP_PORT=587  SMTP_SECURE=false
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=587
SMTP_SECURE=false
EMAIL_USER=votre-email@votre-domaine.com
EMAIL_PASS=votre-mot-de-passe-smtp